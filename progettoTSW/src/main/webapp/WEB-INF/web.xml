<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <!--web.xml é il deployment descriptor, cioé un file che contiene tutte le direttive su come l'applicazione deve usare le vaire risorse  -->
    
    
    <resource-ref>
    
    	<description>
    	Riferimento JNDI ad un data source
    	Dichiaro che la mia applicazione utilizza una risorsa JNDI chiamata jdbc/ProgettoTSW
    	</description>
    	
    	<res-ref-name>jdbc/ProgettoTSW</res-ref-name>
    	<res-type>javax.sql.DataSource</res-type>
    	<res-auth>Container</res-auth>

    </resource-ref>    
         
   
   <!-- pagine di errore personalizzate -->
    <error-page>
    	<error-code> 404</error-code>
    	<location>/errori/NotFound.jsp </location>
    </error-page>
     
       <error-page>
    	<error-code> 500</error-code>
    	<location>/errori/ServerErr.jsp </location>
    </error-page>
     
     
       <error-page>
    	<error-code> 403</error-code>
    	<location>/errori/NoPermessi.jsp </location>
    </error-page>
   
   
   
   
</web-app>
